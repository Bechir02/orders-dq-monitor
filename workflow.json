    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(item => item.json);\n\nconst validDates = rows\n  .map(row => new Date(row.order_date))\n  .filter(d => !isNaN(d.getTime()));\n\nconst mostRecentDate = validDates.length > 0 \n  ? new Date(Math.max(...validDates.map(d => d.getTime())))\n  : null;\n\nconst now = new Date();\nconst hoursSinceLastOrder = mostRecentDate \n  ? (now - mostRecentDate) / (1000 * 60 * 60)\n  : 9999;\n\nconst isFresh = hoursSinceLastOrder <= 24;\nconst freshnessWarning = !isFresh \n  ? \"WARNING: No new orders in the last 24 hours. Last order date: \" + (mostRecentDate ? mostRecentDate.toISOString() : \"unknown\")\n  : \"Data is fresh. Last order: \" + (mostRecentDate ? mostRecentDate.toISOString() : \"unknown\");\n\nreturn rows.map(row => ({\n  json: {\n    ...row,\n    _freshness_ok: isFresh,\n    _freshness_warning: freshnessWarning,\n    _hours_since_last_order: Math.round(hoursSinceLastOrder)\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        -144
      ],
      "id": "a323f8cb-fd7c-4f2c-bae3-80fefb8bd270",
