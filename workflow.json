    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(item => item.json);\n\nconst failures = [];\nconst seenOrderIds = new Set();\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst requiredFields = ['order_id', 'customer_id', 'amount', 'order_date'];\n\nrows.forEach((row, index) => {\n  const rowNum = index + 2;\n  const rowFailures = [];\n\n  requiredFields.forEach(field => {\n    const val = row[field];\n    if (val === undefined || val === null || String(val).trim() === '') {\n      rowFailures.push(`Missing required field: ${field}`);\n    }\n  });\n\n  if (row.order_id && String(row.order_id).trim() !== '') {\n    const oid = String(row.order_id).trim();\n    if (seenOrderIds.has(oid)) {\n      rowFailures.push(`Duplicate order_id: ${oid}`);\n    } else {\n      seenOrderIds.add(oid);\n    }\n  }\n\n  const amount = parseFloat(row.amount);\n  if (!isNaN(amount) && amount <= 0) {\n    rowFailures.push(`Amount is zero or negative: ${row.amount}`);\n  }\n\n  const dateStr = String(row.order_date || '').trim();\n  const dateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;\n  const parsedDate = new Date(dateStr);\n  const isValidFormat = dateRegex.test(dateStr) && !isNaN(parsedDate.getTime());\n\n  if (dateStr !== '' && !isValidFormat) {\n    rowFailures.push(`Invalid date format: ${row.order_date}`);\n  }\n\n  if (isValidFormat) {\n    const orderDate = new Date(dateStr);\n    orderDate.setHours(0, 0, 0, 0);\n    if (orderDate > today) {\n      rowFailures.push(`Future order_date: ${row.order_date}`);\n    }\n  }\n\n  if (rowFailures.length > 0) {\n    failures.push({\n      row_number: rowNum,\n      order_id: row.order_id || '(blank)',\n      issues: rowFailures\n    });\n  }\n});\n\nconst totalRows = rows.length;\nconst failedRows = failures.length;\nconst passedRows = totalRows - failedRows;\n\nreturn [{\n  json: {\n    total_rows: totalRows,\n    passed: passedRows,\n    failed: failedRows,\n    has_failures: failedRows > 0,\n    failures: failures,\n    run_timestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
